# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:8080

# ============================================================
# MongoDB Atlas
# Get your connection string from: https://cloud.mongodb.com
# Replace <username>, <password>, and <cluster> with your values
# ============================================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/francais-pro?retryWrites=true&w=majority

# ============================================================
# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=your_super_strong_jwt_secret_here_at_least_64_chars
JWT_EXPIRES_IN=7d

# ============================================================
# Google OAuth2 (for student sign-in and personal Calendar access)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:5000/api/auth/google/callback
# ============================================================
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ============================================================
# Google Service Account (for creating Google Calendar events & Meet links)
# 1. Go to: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create a service account and download the JSON key
# 3. Save the JSON key as: backend/config/service-account-key.json
# 4. Enable Google Calendar API in your project
# ============================================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=francais-pro@your-project.iam.gserviceaccount.com

# ============================================================
# Email (SMTP) — for booking confirmations & reminders
# For Gmail: use App Password (not your real password)
# Enable 2FA and generate: https://myaccount.google.com/apppasswords
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@francaispro.com
SMTP_PASS=your_gmail_app_password_here
CONTACT_EMAIL=admin@francaispro.com
